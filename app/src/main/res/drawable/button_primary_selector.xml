<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape>
            <gradient
                android:startColor="#6A8DFF"
                android:endColor="#8678FF"
                android:angle="0"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>

    <item>
        <shape>
            <gradient
                android:startColor="#4A7DFF"
                android:endColor="#6A5CFF"
                android:angle="0"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>

</selector>